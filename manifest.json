{
  "manifest_version": 3,
  "name": "Watch Party",
  "version": "1.0",
  "description": "Watch videos in sync with friends across Netflix, YouTube, Prime, Disney+, HiAnime and more.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.netflix.com/*",
    "*://*.amazon.com/*",
    "*://*.primevideo.com/*",
    "*://*.disneyplus.com/*",
    "*://*.max.com/*",
    "*://*.hbomax.com/*",
    "*://*.hulu.com/*",
    "*://*.hianime.biz.pl/*",
    "*://*.megaplay.buzz/*",
    "*://*.animeplay.cfd/*",
    "*://*.streamiloo.to/*",
    "*://*.vidsrc.mov/*",
    "*://*.vsembed.ru/*",
    "*://*.cloudorchestranova.com/*"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": ["socket.io.min.js", "content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.vidsrc.mov/*",
        "*://*.vsembed.ru/*",
        "*://*.cloudorchestranova.com/*"
      ],
      "js": ["player-bridge.js"],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_start"
    }
  ]
}
